# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# setuptools-scm generated at build time
mech_class/_version.py

# Virtual environments
.env
.venv
env/
venv/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
coverage.xml
.mypy_cache/
htmlcov/

# Large data files (stored under /data/; not tracked in repo)
# Parquets, HDF5, large TSV/FASTA
*.parquet
*.h5
*.hdf5
*.fasta
*.fa
*.fastq
*.gz
*.bz2
*.tar
*.zip
*.7z

# Exceptions: small curated files that SHOULD be tracked
!data/review_queue_annotated.tsv
!data/review_queue_annotated_final.tsv
!data/review_queue_summary.json

# Model checkpoints (provided as raw data, not GitHub)
*.pkl
*.pt
*.bin
*.safetensors
# data/models/ contains trained binary artifacts - provided as raw data
/data/models/
# NOTE: mech_class/models/ is a Python package and must NOT be ignored
/data/embeddings/
/data/graphs/

# Notebooks / Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE / OS
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
desktop.ini
*~

# Sphinx docs build
docs/_build/
docs/api/_autosummary/

# Temporary / scratch scripts
scripts/_tmp_*.py
scripts/*_orig.py

# Rclone
rclone.conf

# Secrets
.env.local
*.pem
*.key
secrets/
